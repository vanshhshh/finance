{
  "name": "@finance-platform/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx prisma generate && npx tsup src/server.ts --format esm --target node22 --out-dir dist",
    "dev": "npx tsx watch src/server.ts",
    "import:workbooks": "npx tsx src/scripts/import-workbooks.ts",
    "lint": "npx tsc --noEmit",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@finance-platform/shared": "*",
    "@prisma/client": "^6.5.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.0.7",
    "nodemailer": "^6.10.0",
    "resend": "^4.2.0",
    "socket.io": "^4.8.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
