{
  "name": "finance-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:shared": "npm --workspace @finance-platform/shared run build",
    "build:api": "npm --workspace @finance-platform/api run build",
    "build:web": "npm --workspace @finance-platform/web run build",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @finance-platform/api run dev",
    "dev:web": "npm --workspace @finance-platform/web run dev",
    "lint": "npm-run-all lint:*",
    "lint:api": "npm --workspace @finance-platform/api run lint",
    "lint:web": "npm --workspace @finance-platform/web run lint",
    "prisma:generate": "npm --workspace @finance-platform/api run prisma:generate",
    "prisma:migrate": "npm --workspace @finance-platform/api run prisma:migrate",
    "seed": "npm --workspace @finance-platform/api run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
